{
  "name": "torneo-papaleo-webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:migrate": "npx tsx db/migrate.ts",
    "db:fresh": "npx tsx --env-file .env.local db/migrate.ts && npx tsx --env-file .env.local db/seeds/seed-reset.ts && npx tsx --env-file .env.local db/seeds/seed-base.ts",
    "db:seed:base": "npx tsx --env-file .env.local db/seeds/seed-base.ts",
    "db:seed:reset": "npx tsx --env-file .env.local db/seeds/seed-reset.ts && npx tsx --env-file .env.local db/seeds/seed-base.ts",
    "db:seed:groups-done": "npx tsx --env-file .env.local db/seeds/seed-groups-done.ts",
    "db:seed:finished": "npx tsx --env-file .env.local db/seeds/seed-finished.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "iron-session": "^8.0.4",
    "jose": "^6.2.3",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
